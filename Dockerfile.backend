FROM node:24-alpine
WORKDIR /app
COPY backend/package*.json ./
RUN apk add --no-cache --virtual .build-deps python3 make g++ && \
    npm ci --omit=dev && \
    apk del .build-deps
COPY backend/ ./
RUN mkdir -p /data
VOLUME ["/data"]
ENV PORT=3001 DB_PATH=/data/hcad.db
EXPOSE 3001
CMD ["node", "server.js"]
